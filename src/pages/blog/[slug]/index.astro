---
import { getCollection, render } from "astro:content";
import MarkdownPostLayout from "@layouts/MarkdownPostLayout.astro";

export async function getStaticPaths() {
  const blogEntries = await getCollection("posts");
  const publishedEntries = blogEntries.filter((entry) => !entry.data.draft);

  const headings = await Promise.all(
    publishedEntries.map((entry) => render(entry).then((data) => data.headings)),
  );

  return publishedEntries.map((entry, idx) => ({
    params: { slug: entry.id },
    props: { entry, headings: headings[idx] },
  }));
}

const { entry, headings } = Astro.props;
const { Content } = await render(entry);
---

<MarkdownPostLayout {...entry.data} {headings}>
  <Content />
</MarkdownPostLayout>
