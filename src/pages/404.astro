---
import { ButtonLink, Flex, Heading, Section } from "@components/atoms";
import Layout from "@layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import { t, getLocale } from "@i18n";
import { getRelativeLocaleUrl } from "astro:i18n";

export const prerender = false;

const locale = getLocale(Astro.currentLocale);
const strings = t(locale);
---

<Layout
  title={strings.meta.notFoundTitle}
  description={strings.meta.notFoundDescription}
>
  <Section class="pt-28 pb-24 sm:pt-36 sm:pb-32 gap-0 min-h-[70svh] justify-center">
    <Flex class="flex-col items-center gap-4 text-center">
      <div class="shrink-0 w-24 sm:w-32">
        <video
          data-autoplay-video
          autoplay
          loop
          muted
          playsinline
          preload="auto"
          disablepictureinpicture
          class="w-full"
          poster="/videos/404-avatar-poster.webp"
        >
          <source src="/videos/404-avatar.mp4" type="video/mp4" />
        </video>
        <script src="@scripts/video-autoplay.ts"></script>
        <noscript>
          <img
            width="480"
            height="854"
            loading="eager"
            src="/videos/404-avatar-poster.webp"
            alt={strings.notFound.imgAlt}
            class="w-full"
          />
        </noscript>
      </div>

      <Heading level={1} class="text-7xl sm:text-9xl tracking-tight">
        <span class="text-gradient">404</span>
      </Heading>
      <Heading level={2} class="text-xl sm:text-2xl">
        {strings.notFound.subtitle}
      </Heading>
      <ButtonLink href={getRelativeLocaleUrl(locale, "/")}>
        <Icon name="mdi:arrow-left" size={18} />
        {strings.notFound.backHome}
      </ButtonLink>
    </Flex>
  </Section>
</Layout>
