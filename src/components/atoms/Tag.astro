---
import { cn } from "@utils/cn";
import type { JSX } from "astro/jsx-runtime";

type Props = {
  variant?: keyof typeof variants;
} & JSX.IntrinsicElements["span"];

const variants = {
  default:
    "text-sm px-3 py-1.5 rounded-lg bg-card border border-border text-foreground transition-colors hover:border-primary/30 hover:bg-muted",
  mono: "text-xs font-mono px-2 py-0.5 rounded-md bg-muted text-muted-foreground",
} as const;

const { variant = "default", class: className, ...rest } = Astro.props;
---

<span class={cn(variants[variant], className)} {...rest}>
  <slot />
</span>
