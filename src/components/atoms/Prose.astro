---
import { cn } from "@utils/cn";

const { class: className, ...rest } = Astro.props;
---

<div
  class={cn(
    "prose prose-h1:font-bold prose-h1:text-2xl prose-h2:text-xl prose-h3:text-lg prose-a:text-primary prose-a:underline prose-p:leading-relaxed prose-p:text-muted-foreground prose-li:text-muted-foreground prose-headings:text-foreground prose-strong:text-foreground prose-img:rounded-xl prose-headings:font-semibold prose-code:font-mono prose-code:text-primary prose-pre:bg-card prose-pre:border prose-pre:border-border w-full max-w-none",
    className,
  )}
  {...rest}
>
  <slot />
</div>
