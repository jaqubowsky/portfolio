---
import { cn } from "@utils/cn";

const { class: className, ...rest } = Astro.props;

const noiseStyle = `background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");`;
---

<div class={cn("relative", className)} {...rest}>
  <div
    class="absolute inset-0 pointer-events-none z-0"
    style={noiseStyle}
  >
  </div>
  <div class="relative z-10">
    <slot />
  </div>
</div>
