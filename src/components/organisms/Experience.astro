---
import {
  BulletList,
  Flex,
  GlowCard,
  Heading,
  NoiseBackground,
  Paragraph,
  Section,
} from "@components/atoms";
import { SectionHeader } from "@components/molecules";
import { Image } from "astro:assets";
import { t, getLocale } from "@i18n";
import codeyourbrandLogo from "@images/companies/codeyourbrand.jpg";
import haergiLogo from "@images/companies/haergi.jpg";

const locale = getLocale(Astro.currentLocale);
const strings = t(locale);

type Job = {
  company: string;
  url: string;
  role: string;
  tech: string;
  period: string;
  location: string;
  bullets: readonly string[];
};

const jobs = strings.experience.jobs as unknown as Job[];

const companyLogos: Record<string, ImageMetadata> = {
  CodeYourBrand: codeyourbrandLogo,
  Haergi: haergiLogo,
};
---

<NoiseBackground class="w-full section-fade">
  <Section class="gap-10" id="experience">
    <SectionHeader
      badge={strings.experience.badge}
      title={strings.experience.title}
      description={strings.experience.description}
    />

    <Flex class="flex-col w-full max-w-3xl gap-8">
      {
        jobs.map((job, i) => (
          <div class={`animate-on-scroll stagger-${i + 1}`}>
            <GlowCard class="p-6 sm:p-8">
              <Flex class="flex-col sm:flex-row items-start justify-between gap-2 mb-4">
                <Flex class="flex-col items-start gap-0">
                  <Flex class="items-center gap-3">
                    {companyLogos[job.company] && (
                      <Image
                        src={companyLogos[job.company]}
                        alt={`${job.company} logo`}
                        width={28}
                        height={28}
                        class="rounded-md"
                      />
                    )}
                    <Heading level={3} class="text-xl">
                      <a
                        href={job.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="hover:text-primary transition-colors"
                      >
                        {job.company}
                      </a>
                    </Heading>
                  </Flex>
                  <Paragraph class="text-primary font-semibold text-sm mt-1">
                    {job.role}
                  </Paragraph>
                  <Paragraph class="text-xs font-mono mt-1">
                    {job.tech}
                  </Paragraph>
                </Flex>
                <Flex class="flex-col items-start sm:items-end shrink-0 gap-0">
                  <Paragraph class="text-sm font-mono">
                    {job.period}
                  </Paragraph>
                  <Paragraph class="text-xs">{job.location}</Paragraph>
                </Flex>
              </Flex>

              <BulletList items={[...job.bullets]} />
            </GlowCard>
          </div>
        ))
      }
    </Flex>
  </Section>
</NoiseBackground>
