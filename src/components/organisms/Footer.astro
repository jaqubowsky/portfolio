---
import { Flex, Paragraph } from "@components/atoms";
import { SocialMedia } from "@components/molecules";
import { t, getLocale } from "@i18n";

const locale = getLocale(Astro.url);
const strings = t(locale);

const links = [
  { href: "https://github.com/jaqubowsky", name: "mdi:github" },
  {
    href: "https://www.linkedin.com/in/jakub-nalewajk/",
    name: "mdi:linkedin",
  },
] as const;

const currentYear = new Date().getFullYear();
---

<footer
  class="py-8 px-4 sm:px-6 lg:px-8 border-t border-border/50 w-full mt-auto"
>
  <Flex class="max-w-[1440px] mx-auto flex-col sm:flex-row justify-between gap-4">
    <Paragraph class="text-sm">
      {`© ${currentYear} ${strings.footer.copyright}`}
    </Paragraph>
    <Flex class="items-center gap-4">
      <a
        href="https://status.jnalewajk.me"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-muted-foreground hover:text-foreground transition-colors"
        data-umami-event="status-page"
      >
        {strings.footer.status}
      </a>
      <SocialMedia links={links} />
    </Flex>
  </Flex>
</footer>
