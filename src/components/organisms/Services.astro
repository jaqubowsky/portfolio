---
import {
  Flex,
  GlowCard,
  Grid,
  Heading,
  IconBox,
  Paragraph,
  Section,
} from "@components/atoms";
import { SectionHeader } from "@components/molecules";
import { t, getLocale } from "@i18n";

const locale = getLocale(Astro.currentLocale);
const strings = t(locale);
---

<Section class="gap-10" id="services">
  <SectionHeader
    badge={strings.services.badge}
    title={strings.services.title}
    description={strings.services.description}
  />

  <Grid class="grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 w-full max-w-4xl">
    {
      strings.services.items.map((service, i) => (
        <div class={`animate-on-scroll stagger-${i + 1}`}>
          <GlowCard class="p-6 h-full">
            <Flex class="flex-col gap-3 items-start">
              <IconBox name={service.icon} />
              <Heading level={3} class="text-lg font-semibold">
                {service.title}
              </Heading>
              <Paragraph class="text-sm leading-relaxed">
                {service.description}
              </Paragraph>
            </Flex>
          </GlowCard>
        </div>
      ))
    }
  </Grid>
</Section>
