---
import { Flex, Link } from "@components/atoms";
import { Navigation, ThemeToggler } from "@components/molecules";
import Hamburger from "@components/molecules/Hamburger.astro";
import { Icon } from "astro-icon/components";

const links = [
  { href: "/#experience", text: "Experience" },
  { href: "/#projects", text: "Projects" },
  { href: "/#skills", text: "Skills" },
  { href: "/#contact", text: "Contact" },
  { href: "/blog", text: "Blog" },
] as const;
---

<header
  class="flex items-center justify-between px-4 sm:px-6 lg:px-8 py-3 sticky top-0 left-0 z-50 bg-background/80 backdrop-blur-lg border-b border-border/50"
>
  <Link href="/" class="no-underline font-bold text-lg tracking-tight">
    Jakub<span class="text-primary">.</span>
  </Link>

  <Flex class="justify-between gap-4">
    <Hamburger class="flex lg:hidden" />

    <nav class="hidden lg:flex gap-1 items-center">
      <Navigation links={links} />
    </nav>
    <ThemeToggler />
  </Flex>
</header>

<div
  id="mobile-menu"
  class="fixed inset-0 z-[60] bg-background opacity-0 pointer-events-none transition-opacity duration-300 flex flex-col items-center justify-center gap-2"
>
  <button
    id="mobile-menu-close"
    class="absolute top-4 right-4 p-2 cursor-pointer text-foreground"
    aria-label="Close menu"
  >
    <Icon name="mdi:close" size={28} />
  </button>
  <Navigation links={links} />
</div>
