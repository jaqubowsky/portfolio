---
import { Flex, Heading, Paragraph, Section } from "@components/atoms";
import { t, getLocale } from "@i18n";

const locale = getLocale(Astro.currentLocale);
const strings = t(locale);

const stats = [
  { value: "4+", label: strings.stats.experience },
  { value: "9+", label: strings.stats.projects },
  { value: "5+", label: strings.stats.clients },
];
---

<Section class="py-10 sm:py-14 gap-0">
  <Flex class="flex-wrap justify-center gap-8 sm:gap-16 w-full max-w-3xl">
    {
      stats.map((stat, i) => (
        <Flex class={`flex-col items-center gap-1 animate-on-scroll stagger-${i + 1}`}>
          <Heading level={2} class="text-4xl sm:text-5xl font-bold text-gradient">
            {stat.value}
          </Heading>
          <Paragraph class="text-sm sm:text-base text-muted-foreground font-medium">
            {stat.label}
          </Paragraph>
        </Flex>
      ))
    }
  </Flex>
</Section>
