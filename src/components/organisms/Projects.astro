---
import { Picture } from "astro:assets";
import {
  Flex,
  GlowCard,
  Heading,
  Link,
  Paragraph,
  Section,
  Tag,
} from "@components/atoms";
import { SectionHeader } from "@components/molecules";
import { Icon } from "astro-icon/components";
import pillPilotImg from "@images/projects/pill-pilot.webp";
import jobzImg from "@images/projects/jobz.webp";
import substatzImg from "@images/projects/substatz.webp";
import { t, getLocale } from "@i18n";

const locale = getLocale(Astro.currentLocale);
const strings = t(locale);

const projects = [
  {
    number: "01",
    title: "PillPilot",
    description: strings.projects.items[0].description,
    tech: ["Next.js 16", "Vercel AI SDK", "Drizzle ORM", "PWA", "web-push"],
    github: "https://github.com/jaqubowsky/pill-pilot",
    live: "https://pill.jnalewajk.me",
    image: pillPilotImg,
    featured: true as const,
  },
  {
    number: "02",
    title: "jobZ",
    description: strings.projects.items[1].description,
    tech: ["Next.js 16", "Supabase", "Transformers.js", "Turborepo"],
    github: "https://github.com/jaqubowsky/jobZ",
    live: "https://jobzzz.jnalewajk.me",
    image: jobzImg,
    featured: false as const,
  },
  {
    number: "03",
    title: "SubStatZ",
    description: strings.projects.items[2].description,
    tech: ["Next.js 16", "Prisma", "Stripe", "Sentry", "Docker"],
    github: "https://github.com/jaqubowsky/substatz",
    live: "https://substatz.jnalewajk.me",
    image: substatzImg,
    featured: false as const,
  },
];
---

<Section class="gap-10" id="projects">
  <SectionHeader
    badge={strings.projects.badge}
    title={strings.projects.title}
    description={strings.projects.description}
  />

  <Flex class="flex-col gap-6 w-full">
    {
      projects.map((project, i) => (
        <div class={`animate-on-scroll stagger-${i + 1}`}>
          <GlowCard class="p-0 overflow-hidden">
            <Flex class="flex-col lg:flex-row items-stretch overflow-hidden">
              <div class="lg:w-2/5 shrink-0 overflow-hidden">
                <Picture
                  src={project.image}
                  formats={["avif", "webp"]}
                  width={600}
                  alt={`${project.title} preview`}
                  pictureAttributes={{ style: "width: 100%; max-width: 100%; height: 100%;" }}
                  style="width: 100%; max-width: 100%;"
                  class="h-auto lg:h-full object-contain lg:object-cover bg-muted block"
                  loading="lazy"
                />
              </div>
              <Flex class="flex-col gap-3 p-6 sm:p-8 flex-1 items-start">
                <Flex class="items-start justify-between w-full">
                  <Flex class="gap-3 items-center justify-start">
                    <span class="text-3xl font-bold text-gradient opacity-80 font-mono hidden sm:inline">
                      {project.number}
                    </span>
                    <Heading level={3} class="text-2xl">
                      {project.title}
                    </Heading>
                  </Flex>
                  <Flex class="gap-2 shrink-0">
                    <Link
                      href={project.github}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="p-1"
                      aria-label={`${project.title} GitHub`}
                      data-umami-event="project-github"
                      data-umami-event-project={project.title}
                    >
                      <Icon name="mdi:github" size={20} />
                    </Link>
                    {project.live && (
                      <Link
                        href={project.live}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="p-1"
                        aria-label={`${project.title} live demo`}
                        data-umami-event="project-live"
                        data-umami-event-project={project.title}
                      >
                        <Icon name="mdi:open-in-new" size={20} />
                      </Link>
                    )}
                  </Flex>
                </Flex>

                <Paragraph class="text-sm leading-relaxed">
                  {project.description}
                </Paragraph>

                <Flex class="flex-wrap gap-1.5 justify-start mt-auto">
                  {project.tech.map((techItem) => (
                    <Tag variant="mono">{techItem}</Tag>
                  ))}
                </Flex>
              </Flex>
            </Flex>
          </GlowCard>
        </div>
      ))
    }
  </Flex>
</Section>
