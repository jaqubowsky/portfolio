---
import { ButtonLink, Flex, Heading, Paragraph, Section, StatusBadge } from "@components/atoms";
import { Icon } from "astro-icon/components";
---

<Section class="pt-28 pb-24 sm:pt-36 sm:pb-32 gap-0 relative" id="home">
  <Flex class="relative z-10 flex-col md:flex-row md:items-center gap-6 md:gap-8 w-full">
    <Flex class="flex-col items-center md:items-start gap-6 flex-1">
      <Flex class="flex-col gap-2 items-center md:items-start hero-fade">
        <StatusBadge href="https://status.jnalewajk.me" data-umami-event="status-page" />
        <Heading level={1} class="text-center md:text-left text-5xl sm:text-6xl lg:text-7xl tracking-tight">
          <span class="text-gradient">Jakub</span>{" "}Nalewajk
          <span class="block text-lg sm:text-xl text-primary font-semibold font-mono tracking-wide mt-2">
            Frontend Developer
          </span>
        </Heading>
      </Flex>

      <Paragraph class="md:text-left text-center max-w-lg text-base sm:text-lg leading-relaxed hero-fade" style="animation-delay: 0.1s">
        Frontend Developer with 4+ years of experience in the Next.js ecosystem.
        I practice spec-driven development with Claude Code, take full ownership
        of projects from architecture to deployment, and collaborate closely with
        business, backend devs, and designers to ship products that matter.
      </Paragraph>

      <Flex class="justify-start gap-3 hero-fade w-full sm:w-auto flex-col sm:flex-row" style="animation-delay: 0.15s">
        <ButtonLink href="#contact" data-umami-event="hero-contact">
          <Icon name="mdi:email-outline" size={18} />
          Get in Touch
        </ButtonLink>
        <ButtonLink
          href="/01-jakub-nalewajk-cv.pdf"
          variant="secondary"
          target="_blank"
          rel="noopener noreferrer"
          data-umami-event="download-cv"
        >
          <Icon name="mdi:download" size={18} />
          Download CV
        </ButtonLink>
      </Flex>
    </Flex>

    <div class="hero-fade shrink-0 w-56 sm:w-72 relative" style="animation-delay: 0.2s">
      <video
        id="hero-video"
        autoplay
        loop
        muted
        playsinline
        preload="auto"
        disablepictureinpicture
        class="w-full rounded-2xl"
        poster="/videos/avatar-poster.webp"
      >
        <source src="/videos/avatar.mp4" type="video/mp4" />
      </video>
      <script>
        function initHeroVideo() {
          const video = document.getElementById("hero-video") as HTMLVideoElement;
          if (!video) return;
          video.load();
          video.play().catch(() => {
            const play = () => { video.play(); document.removeEventListener("click", play); };
            document.addEventListener("click", play, { once: true });
          });
        }
        initHeroVideo();
        document.addEventListener("astro:page-load", initHeroVideo);
        window.addEventListener("pageshow", (e) => { if (e.persisted) initHeroVideo(); });
      </script>
      <noscript>
        <img
          width="400"
          height="533"
          loading="eager"
          src="/videos/avatar-poster.webp"
          alt="Jakub Nalewajk"
          class="w-full rounded-2xl"
        />
      </noscript>
    </div>
  </Flex>
</Section>
