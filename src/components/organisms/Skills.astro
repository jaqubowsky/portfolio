---
import {
  Flex,
  GlowCard,
  Grid,
  Heading,
  IconBox,
  NoiseBackground,
  Section,
  Tag,
} from "@components/atoms";
import { SectionHeader } from "@components/molecules";
import { t, getLocale } from "@i18n";

const locale = getLocale(Astro.currentLocale);
const strings = t(locale);

const skills = [
  {
    type: strings.skills.categories.frontend,
    icon: "mdi:language-javascript",
    items: [
      "Next.js",
      "React",
      "TypeScript",
      "TailwindCSS",
      "React Query",
      "Nx",
      "Turborepo",
      "Storybook",
    ],
  },
  {
    type: strings.skills.categories.backend,
    icon: "mdi:server",
    items: ["Node.js", "Prisma", "Drizzle", "Supabase", "PostgreSQL"],
  },
  {
    type: strings.skills.categories.devops,
    icon: "mdi:cloud-outline",
    items: ["Docker", "Git", "CI/CD", "GitHub Actions"],
  },
  {
    type: strings.skills.categories.other,
    icon: "mdi:tools",
    items: ["Zod", "Sentry", "Cursor", "Strapi", "Figma", "Claude Code"],
  },
] as const;
---

<NoiseBackground class="w-full section-fade">
  <Section class="gap-10" id="skills">
    <SectionHeader
      badge={strings.skills.badge}
      title={strings.skills.title}
      description={strings.skills.description}
    />

    <Grid class="grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 w-full">
      {
        skills.map((category, i) => (
          <div class={`animate-on-scroll stagger-${i + 1}`}>
            <GlowCard class="p-6 h-full">
              <Flex class="flex-col gap-4 items-start">
                <Flex class="gap-3 items-start">
                  <IconBox name={category.icon} />
                  <Heading
                    level={3}
                    class="text-lg font-semibold mt-1.5"
                  >
                    {category.type}
                  </Heading>
                </Flex>
                <Flex class="flex-wrap gap-2 justify-start">
                  {category.items.map((item) => (
                    <Tag>{item}</Tag>
                  ))}
                </Flex>
              </Flex>
            </GlowCard>
          </div>
        ))
      }
    </Grid>
  </Section>
</NoiseBackground>
