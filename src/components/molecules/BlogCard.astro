---
import { Image } from "astro:assets";
import { Badge, Flex, GlowCard, Heading, Link, Paragraph } from "@components/atoms";
import { formatDate } from "@utils/date";

const { title, description, tags, image, slug, pubDate } = Astro.props;
---

<Link
  href=`/blog/${slug}`
  class="no-underline w-full"
>
  <GlowCard class="overflow-hidden h-full flex flex-col">
    <Image
      transition:name=`blog-image-${title}`
      width={600}
      height={300}
      loading="eager"
      class="w-full h-48 object-cover"
      src={image.url}
      alt={image.alt}
    />
    <Flex class="flex-col py-5 px-5 flex-1 gap-3 items-start">
      {
        tags && (
          <Flex class="flex-wrap gap-1.5 justify-start">
            {tags.map((tag: string) => (
              <Badge class="rounded-md text-[10px]" variant="secondary">
                {tag}
              </Badge>
            ))}
          </Flex>
        )
      }

      <Heading
        level={3}
        transition:name=`blog-heading-${title}`
        class="text-xl font-bold leading-snug"
      >
        {title}
      </Heading>

      <Paragraph class="text-sm leading-relaxed line-clamp-3">
        {description}
      </Paragraph>

      <Paragraph class="text-xs opacity-60 mt-auto">
        {formatDate(pubDate)}
      </Paragraph>
    </Flex>
  </GlowCard>
</Link>
