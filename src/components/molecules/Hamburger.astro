---
import { cn } from "@utils/cn";

const { class: className } = Astro.props;
---

<script is:inline>
  document.addEventListener("astro:page-load", () => {
    const button = document.querySelector("#hamburger");
    const overlay = document.querySelector("#mobile-menu");
    if (!button || !overlay) return;

    function openMenu() {
      overlay.classList.remove("opacity-0", "pointer-events-none");
      document.body.style.overflow = "hidden";
    }

    function closeMenu() {
      overlay.classList.add("opacity-0", "pointer-events-none");
      document.body.style.overflow = "";
    }

    button.addEventListener("click", () => {
      const isOpen = !overlay.classList.contains("opacity-0");
      if (isOpen) closeMenu();
      else openMenu();
    });

    overlay.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", closeMenu);
    });

    const closeBtn = document.querySelector("#mobile-menu-close");
    if (closeBtn) closeBtn.addEventListener("click", closeMenu);

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") closeMenu();
    });
  });
</script>

<button
  id="hamburger"
  class={cn("relative cursor-pointer flex flex-col gap-1.5 z-[70]", className)}
  aria-label="Toggle navigation menu"
>
  <span class="block w-6 h-0.5 bg-foreground transition-all duration-300"></span>
  <span class="block w-6 h-0.5 bg-foreground transition-all duration-300"></span>
  <span class="block w-6 h-0.5 bg-foreground transition-all duration-300"></span>
</button>
