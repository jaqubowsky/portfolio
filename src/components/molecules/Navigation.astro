---
import { Link } from "@components/atoms";

type NavLink = {
  href: string;
  text: string;
};

const { links } = Astro.props;
---

<nav>
  <ul class="flex flex-col lg:flex-row gap-2 lg:gap-1 p-2 lg:p-0 bg-transparent items-center">
    {
      links.map(({ href, text }: NavLink) => (
        <li>
          <Link
            href={href}
            class="block px-4 py-3 lg:px-3 lg:py-2 text-2xl lg:text-sm text-foreground lg:text-muted-foreground rounded-md hover:text-primary lg:hover:text-foreground lg:hover:bg-muted/50 no-underline transition-colors"
          >
            {text}
          </Link>
        </li>
      ))
    }
  </ul>
</nav>
