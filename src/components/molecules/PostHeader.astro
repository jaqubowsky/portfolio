---
import { Picture } from "astro:assets";
import { Badge, Flex, Heading, Paragraph } from "@components/atoms";
import { t, getLocale, formatDate } from "@i18n";

const locale = getLocale(Astro.currentLocale);
const strings = t(locale);
const { frontmatter } = Astro.props;

const placeholders: Record<string, string> = {
  author: frontmatter.author,
  date: formatDate(frontmatter.pubDate, locale),
};
const postMeta = strings.blog.postMeta.replace(
  /\{(\w+)\}/g,
  (_, key: string) => placeholders[key] ?? `{${key}}`,
);
---

<Flex class="flex-col items-start gap-4">
  <Badge variant="secondary">{frontmatter.category}</Badge>
  <Heading
    transition:name=`blog-heading-${frontmatter.title}`
    level={1}
    class="text-3xl sm:text-4xl md:text-5xl leading-tight"
  >
    {frontmatter.title}
  </Heading>
  <Paragraph class="text-base">
    {postMeta}
  </Paragraph>
  <Picture
    transition:name=`blog-image-${frontmatter.title}`
    formats={["avif", "webp"]}
    loading="eager"
    width={800}
    src={frontmatter.image.url}
    alt={frontmatter.image.alt}
    pictureAttributes={{ style: "width: 100%; max-width: 100%;" }}
    style="width: 100%; max-width: 100%;"
    class="object-cover rounded-xl"
  />
</Flex>
