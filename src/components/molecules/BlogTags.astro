---
import { Flex, Link } from "@components/atoms";
import { cn } from "@utils/cn";
import { getLocale } from "@i18n";
import { getRelativeLocaleUrl } from "astro:i18n";

interface Props {
  class?: string;
  tags: string[];
}

const locale = getLocale(Astro.currentLocale);
const { class: className, tags } = Astro.props;
---

<Flex class="flex-wrap gap-2 items-start justify-start mt-4">
  {
    tags.map((tag: string) => (
      <Link
        href={getRelativeLocaleUrl(locale, `/category/${tag}`)}
        class={cn("decoration-wavy underline text-muted-foreground hover:text-primary", className)}
      >
        #{tag}
      </Link>
    ))
  }
</Flex>
