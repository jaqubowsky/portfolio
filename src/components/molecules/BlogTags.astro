---
import { Flex, Link } from "@components/atoms";
import { cn } from "@utils/cn";
import { getLocalizedPathname, getLocale } from "@i18n";

interface Props {
  class?: string;
  tags: string[];
}

const locale = getLocale(Astro.url);
const { class: className, tags } = Astro.props;
---

<Flex class="flex-wrap gap-2 items-start justify-start mt-4">
  {
    tags.map((tag: string) => (
      <Link
        href={getLocalizedPathname(`/category/${tag}`, locale)}
        class={cn("decoration-wavy underline", className)}
      >
        #{tag}
      </Link>
    ))
  }
</Flex>
