---
import {
  getAlternateLocales,
  getLocale,
  getLocalizedPathname,
  stripLocaleFromPath,
  LOCALE_LABELS,
} from "@i18n";

const locale = getLocale(Astro.url);

const [targetLocale] = getAlternateLocales(locale);
const basePath = stripLocaleFromPath(Astro.url.pathname);
const href = getLocalizedPathname(basePath, targetLocale);
---

<a
  href={href}
  class="px-2 py-1 text-xs font-mono rounded-md border border-border text-muted-foreground hover:text-foreground hover:bg-muted/50 no-underline transition-colors"
  data-locale-switch={targetLocale}
  data-astro-prefetch
>
  {LOCALE_LABELS[targetLocale]}
</a>

<script>
  function initLanguageSwitcher() {
    for (const link of document.querySelectorAll<HTMLAnchorElement>("[data-locale-switch]")) {
      const targetLocale = link.dataset.localeSwitch;

      const hreflangLink = document.querySelector<HTMLLinkElement>(
        `link[rel="alternate"][hreflang="${targetLocale}"]`,
      );
      if (hreflangLink?.href) {
        link.href = new URL(hreflangLink.href).pathname;
      }

      link.addEventListener("click", () => {
        const secure = location.protocol === "https:" ? "; secure" : "";
        document.cookie = `preferred-locale=${targetLocale}; path=/; max-age=31536000; samesite=lax${secure}`;
      });
    }
  }
  initLanguageSwitcher();
  document.addEventListener("astro:page-load", initLanguageSwitcher);
</script>
