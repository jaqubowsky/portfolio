---
import { Heading, Link } from "@components/atoms";
import { cn } from "@utils/cn";
import { t, getLocale } from "@i18n";

const locale = getLocale(Astro.url);
const strings = t(locale);
const { headings } = Astro.props;

type HeadingItem = {
  depth: number;
  text: string;
  slug: string;
};

const getIndentation = (depth: number) => {
  switch (depth) {
    case 2:
      return "ml-0";
    case 3:
      return "ml-4";
    case 4:
      return "ml-8";
    case 5:
      return "ml-12";
    case 6:
      return "ml-14";
    default:
      return "ml-0";
  }
};

const { class: className, withIndentation } = Astro.props;

const filteredHeadings = headings.filter((h: HeadingItem) => h.depth > 1);
---

<script src="@scripts/toc-highlight.ts"></script>

<div class={cn("border border-border rounded-xl p-5 bg-card", className)}>
  <Heading class="text-base font-semibold mb-3" level={2}>
    {strings.blog.onThisPage}
  </Heading>
  <nav>
    <ol class="space-y-1.5 list-none">
      {
        filteredHeadings.map((heading: HeadingItem, index: number) => (
            <li
              class={cn(
                "flex gap-2",
                withIndentation && getIndentation(heading.depth),
              )}
            >
              <span class="text-xs font-mono text-primary/50 mt-0.5 shrink-0 w-5 text-right">
                {String(index + 1).padStart(2, "0")}
              </span>
              <Link
                href={`#${heading.slug}`}
                title={heading.text}
                data-toc-link
                class="text-sm text-muted-foreground hover:text-foreground transition-colors leading-snug"
              >
                {heading.text}
              </Link>
            </li>
          ))
      }
    </ol>
  </nav>
</div>
