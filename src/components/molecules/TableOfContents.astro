---
import { Heading, Link } from "@components/atoms";
import { cn } from "@utils/cn";

const { headings } = Astro.props;

type HeadingItem = {
  depth: number;
  text: string;
  slug: string;
};

const getIndentation = (depth: number) => {
  switch (depth) {
    case 2:
      return "ml-0";
    case 3:
      return "ml-4";
    case 4:
      return "ml-8";
    case 5:
      return "ml-12";
    case 6:
      return "ml-14";
    default:
      return "ml-0";
  }
};

const { class: className, withIndentation } = Astro.props;

const filteredHeadings = headings.filter((h: HeadingItem) => h.depth > 1);
let counter = 0;
---

<script>
  function initTocHighlight() {
    const tocLinks = document.querySelectorAll("[data-toc-link]");
    if (!tocLinks.length) return;

    const headingEls = Array.from(tocLinks).map((link) => {
      const slug = link.getAttribute("href")?.replace("#", "");
      return slug ? document.getElementById(slug) : null;
    }).filter(Boolean) as HTMLElement[];

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            const id = entry.target.id;
            for (const link of tocLinks) {
              const isActive = link.getAttribute("href") === `#${id}`;
              link.classList.toggle("!text-primary", isActive);
              link.classList.toggle("!text-foreground", isActive);
              link.classList.toggle("font-semibold", isActive);
            }
          }
        }
      },
      { rootMargin: "-80px 0px -60% 0px", threshold: 0 },
    );

    for (const el of headingEls) {
      observer.observe(el);
    }
  }

  initTocHighlight();
  document.addEventListener("astro:page-load", initTocHighlight);
</script>

<div class={cn("border border-border rounded-xl p-5 bg-card", className)}>
  <Heading class="text-base font-semibold mb-3" level={2}>
    On this page
  </Heading>
  <nav>
    <ol class="space-y-1.5 list-none">
      {
        filteredHeadings.map((heading: HeadingItem) => {
          counter++;
          return (
            <li
              class={cn(
                "flex gap-2",
                withIndentation && getIndentation(heading.depth),
              )}
            >
              <span class="text-xs font-mono text-primary/50 mt-0.5 shrink-0 w-5 text-right">
                {String(counter).padStart(2, "0")}
              </span>
              <Link
                href={`#${heading.slug}`}
                title={heading.text}
                data-toc-link
                class="text-sm text-muted-foreground hover:text-foreground transition-colors leading-snug"
              >
                {heading.text}
              </Link>
            </li>
          );
        })
      }
    </ol>
  </nav>
</div>
