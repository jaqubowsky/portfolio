---
import "../styles/global.css";

import { ClientRouter } from "astro:transitions";
import { Footer, Header } from "@components/organisms";
import {
  getSeoData,
  getBreadcrumbJsonLd,
  getFaqJsonLd,
  AUTHOR,
  type BreadcrumbItem,
  type FaqItem,
} from "@utils/seo";
import { DEFAULT_LOCALE, LOCALES } from "@i18n/config";

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: "website" | "article";
  publishedDate?: Date;
  alternateHref?: string;
  noindex?: boolean;
  breadcrumbs?: BreadcrumbItem[];
  faqItems?: readonly FaqItem[];
  keywords?: string;
}

const seo = getSeoData({ url: Astro.url, site: Astro.site, ...Astro.props });
const {
  title,
  description,
  type = "website",
  publishedDate,
  noindex = false,
  breadcrumbs,
  faqItems,
  keywords,
} = Astro.props;
const breadcrumbJsonLd = breadcrumbs ? getBreadcrumbJsonLd(breadcrumbs) : null;
const faqJsonLd = faqItems ? getFaqJsonLd(faqItems) : null;
---

<!doctype html>
<html lang={seo.lang} class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="canonical" href={seo.canonicalURL} />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preload" href="/fonts/outfit-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/jetbrains-mono-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="dns-prefetch" href="https://umami.jnalewajk.me" />

    {LOCALES.map((l) => (
      <link rel="alternate" hreflang={l} href={seo.hreflangUrls[l]} />
    ))}

    <link rel="alternate" hreflang="x-default" href={seo.hreflangUrls[DEFAULT_LOCALE]} />

    {AUTHOR.socials.map((url) => (
      <link rel="me" href={url} />
    ))}

    <meta name="generator" content={Astro.generator} />
    {noindex && <meta name="robots" content="noindex, follow" />}
    <meta name="description" content={description} />
    <meta name="author" content="Jakub Nalewajk" />
    <meta name="keywords" content={keywords ?? seo.strings.meta.keywords} />
    <title>{title}</title>

    <meta property="og:type" content={type} />
    <meta property="og:url" content={seo.canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={seo.imageURL} />
    <meta property="og:site_name" content="Jakub Nalewajk" />
    <meta property="og:locale" content={seo.ogLocale} />
    {seo.ogLocaleAlternates.map((alt) => (
      <meta property="og:locale:alternate" content={alt} />
    ))}

    {publishedDate && (
      <meta property="article:published_time" content={publishedDate.toISOString()} />
    )}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={seo.imageURL} />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(seo.jsonLd)} />
    {breadcrumbJsonLd && (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
    )}
    {faqJsonLd && (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
    )}

    {import.meta.env.PROD && (
      <script defer src="https://umami.jnalewajk.me/script.js" data-website-id="a755b16f-2436-40eb-a400-d39ddbcaefdb" is:inline></script>
    )}
    <script is:inline>
      (function() {
        var theme = localStorage.getItem("theme");
        if (theme === "light") {
          document.documentElement.classList.remove("dark");
        } else {
          document.documentElement.classList.add("dark");
        }
      })();
    </script>
    <ClientRouter />
  </head>
  <body class="bg-background text-foreground min-h-svh flex flex-col">
    <Header />
    <main class="flex flex-col">
      <slot />
    </main>
    <Footer />

    <script src="@scripts/scroll-animations.ts"></script>
  </body>
</html>
