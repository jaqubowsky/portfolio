---
import { ButtonLink, Flex, Prose, Section } from "@components/atoms";
import { BackToTop, BlogTags, PostHeader, ShareLinks, TableOfContents } from "@components/molecules";
import Layout from "@layouts/Layout.astro";
import { Icon } from "astro-icon/components";

const frontmatter = Astro.props;
---

<Layout
  title={frontmatter.title}
  description={frontmatter.description}
  image={frontmatter.image?.url}
  type="article"
  publishedDate={frontmatter.pubDate}
>
  <Section
    class="relative grid xl:grid-cols-[1fr_auto_1fr] gap-x-8 max-w-7xl mx-auto"
  >
    <div class="w-full hidden xl:block h-full">
      <div class="sticky top-28">
        <TableOfContents
          headings={frontmatter.headings}
          withIndentation
          class="max-w-60"
        />
        <ButtonLink href="/blog" variant="secondary" class="mt-4 ml-1 text-sm w-full max-w-60">
          <Icon name="mdi:arrow-left" size={16} />
          Back to Blog
        </ButtonLink>
      </div>
    </div>

    <article class="flex flex-col w-full max-w-2xl gap-y-10">
      <PostHeader frontmatter={frontmatter} />
      <Flex class="flex-col gap-4 xl:hidden static items-start">
        <TableOfContents headings={frontmatter.headings} class="w-full" />
        <ButtonLink href="/blog" variant="secondary" class="text-sm self-start">
          <Icon name="mdi:arrow-left" size={16} />
          Back to Blog
        </ButtonLink>
      </Flex>
      <Prose>
        <slot />
      </Prose>

      <template id="copy-icon">
        <Icon name="mdi:content-copy" size={16} />
      </template>
      <template id="check-icon">
        <Icon name="mdi:check" size={16} />
      </template>

      <script>
        const copyIcon = document.getElementById("copy-icon") as HTMLTemplateElement;
        const checkIcon = document.getElementById("check-icon") as HTMLTemplateElement;

        document.querySelectorAll("pre").forEach((pre) => {
          const wrapper = document.createElement("div");
          wrapper.className = "relative group";
          pre.parentNode?.insertBefore(wrapper, pre);
          wrapper.appendChild(pre);

          const button = document.createElement("button");
          button.className =
            "absolute right-2 top-2 p-1.5 rounded-md bg-muted/80 text-muted-foreground opacity-0 group-hover:opacity-100 hover:bg-muted hover:text-foreground transition-all cursor-pointer";
          button.setAttribute("aria-label", "Copy code");
          button.appendChild(copyIcon.content.cloneNode(true));

          button.addEventListener("click", async () => {
            const code = pre.querySelector("code")?.textContent ?? pre.textContent ?? "";
            await navigator.clipboard.writeText(code);
            button.replaceChildren(checkIcon.content.cloneNode(true));
            setTimeout(() => {
              button.replaceChildren(copyIcon.content.cloneNode(true));
            }, 2000);
          });

          wrapper.appendChild(button);
        });
      </script>
      <BlogTags tags={frontmatter.tags} />
      <ShareLinks />
    </article>
  </Section>

  <BackToTop />
</Layout>
